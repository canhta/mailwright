MAIL_FOLDER=Inbox
SENDER_ALLOWLIST=product-team@example.com, example.com
COMPANY_DOMAIN=example.com
OWA_STATE_PATH=data/owa_state.enc
# If set, `mailwright login` pushes the captured session to this VPS endpoint
# (POST <url>/owa/session) instead of writing it locally.
OWA_UPLOAD_URL=
OWA_UPLOAD_SECRET=
DB_PATH=data/app.db
FERNET_KEY=
POLL_INTERVAL_SECONDS=180
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
# LLM provider — any OpenAI-compatible endpoint. Leave LLM_BASE_URL empty for OpenAI.
LLM_API_KEY=
LLM_BASE_URL=
LLM_CLASSIFY_MODEL=gpt-4o-mini
LLM_DRAFT_MODEL=gpt-4o
LLM_STRUCTURED_MODE=json_schema
CONFIDENCE_THRESHOLD=0.8
# DeepSeek: LLM_BASE_URL=https://api.deepseek.com  LLM_CLASSIFY_MODEL=deepseek-chat  LLM_DRAFT_MODEL=deepseek-chat  LLM_STRUCTURED_MODE=json_object
# Ollama:   LLM_BASE_URL=http://localhost:11434/v1  LLM_API_KEY=ollama  LLM_CLASSIFY_MODEL=llama3.1  LLM_STRUCTURED_MODE=json_object
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWLIST=
WEBHOOK_SECRET=
WEBHOOK_PORT=8080
STATUS_TARGETS=In Prod,Done
SUMMARY_TIME=08:00
SUMMARY_WINDOW_HOURS=24
NUDGE_STALE_DAYS=3
# Embeddings — point at OpenAI or a local Ollama instance (chat LLM may differ)
EMBED_API_KEY=
EMBED_BASE_URL=
EMBED_MODEL=text-embedding-3-small
MEMORY_TOPK=4
